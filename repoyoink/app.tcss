/* RepoYoink – TUI Stylesheet */
/* Dark theme inspired by lazygit and modern terminal tools */

Screen {
    background: $surface;
    align: center middle;
}

/* ─── URL Input Screen ─── */

URLScreen {
    align: center middle;
}

#url-container {
    width: 80%;
    max-width: 120;
    height: auto;
    border: thick $primary;
    padding: 2 4;
    background: $surface;
    margin: 1 2;
}

#logo-text {
    text-align: center;
    width: 100%;
    color: $text;
    text-style: bold;
    margin-bottom: 2;
}

#url-subtitle {
    text-align: center;
    width: 100%;
    color: $text-muted;
    margin-bottom: 2;
}

#url-input {
    width: 100%;
    margin-bottom: 2;
}

#url-error {
    color: $error;
    text-align: center;
    width: 100%;
    display: none;
    margin-bottom: 1;
}

#url-status {
    color: $accent;
    text-align: center;
    width: 100%;
    display: none;
    margin-bottom: 1;
}

#url-help {
    text-align: center;
    color: $text-muted;
    width: 100%;
    margin-top: 1;
}

/* ─── Explorer Screen ─── */

#explorer-screen {
    width: 100%;
    height: 100%;
    layout: vertical;
}

#explorer-header {
    dock: top;
    width: 100%;
    height: auto;
    background: $primary;
    color: $text;
    padding: 1 2;
    layout: horizontal;
}

#header-title {
    width: 1fr;
    content-align: left middle;
    text-style: bold;
}

#header-stats {
    width: auto;
    min-width: 30;
    content-align: right middle;
    color: $text;
}

#explorer-body {
    width: 100%;
    height: 1fr;
    layout: horizontal;
}

#tree-panel {
    width: 1fr;
    height: 100%;
    border-right: thick $primary-darken-2;
    padding: 0 1;
}

#repo-tree {
    width: 100%;
    height: 1fr;
    scrollbar-size: 1 1;
}

#preview-panel {
    width: 50%;
    height: 100%;
    display: none;
    padding: 0 2;
    overflow-y: auto;
    border-left: thick $primary-darken-2;
}

#preview-title {
    dock: top;
    width: 100%;
    height: auto;
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    padding: 1 2;
    margin-bottom: 1;
}

#preview-content {
    width: 100%;
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

#search-bar {
    dock: bottom;
    width: 100%;
    margin: 1 2;
    display: none;
}

#footer-bar {
    dock: bottom;
    width: 100%;
    height: auto;
    background: $primary-darken-3;
    color: $text-muted;
    padding: 1 2;
    text-align: center;
}

/* ─── Download Screen ─── */

DownloadScreen {
    align: center middle;
}

#download-container {
    width: 80%;
    max-width: 120;
    height: auto;
    border: thick $success;
    padding: 2 4;
    background: $surface;
    margin: 1 2;
}

#download-title {
    text-align: center;
    text-style: bold;
    color: $success;
    width: 100%;
    margin-bottom: 2;
}

#download-progress {
    width: 70%;
    margin-bottom: 1;
}

#download-percentage {
    text-align: center;
    width: 100%;
    margin-bottom: 1;
    color: $text;
}

#download-status {
    text-align: center;
    color: $text-muted;
    width: 100%;
}

#download-file {
    text-align: center;
    color: $text-muted;
    width: 100%;
    margin-top: 1;
}

#download-done {
    text-align: center;
    color: $success;
    width: 100%;
    margin-top: 2;
    display: none;
}

/* ─── Tree styling ─── */

Tree {
    scrollbar-background: $surface;
    scrollbar-color: $primary-darken-1;
    scrollbar-color-hover: $primary;
    scrollbar-color-active: $primary-lighten-1;
}

Tree > .tree--cursor {
    background: $primary-darken-2;
    color: $text;
    text-style: bold;
}

Tree > .tree--highlight {
    background: $primary-darken-3;
}

/* ─── Misc ─── */

LoadingIndicator {
    color: $primary;
}
